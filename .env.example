# Supabase (client-safe — use NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Server-only: doctor invite & customer lookup (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL for Supabase auth redirect links (doctor invite → set password)
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
